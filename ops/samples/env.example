# Malla Configuration
# Copy this file to .env and adjust the values as needed

# =============================================================================
# Docker Configuration
# =============================================================================

# Docker image to use (leave as default to use pre-built images from GHCR)
# MALLA_IMAGE=ghcr.io/aminovpavel/meshworks-malla:latest

# Port to expose the web UI on (default: 5008)
# MALLA_WEB_PORT=5008

# Web server command (choose between Flask dev server and Gunicorn)
# Default: /app/.venv/bin/malla-web (Flask development server)
# Production: /app/.venv/bin/malla-web-gunicorn (Gunicorn WSGI server)
# MALLA_WEB_COMMAND=/app/.venv/bin/malla-web-gunicorn

# =============================================================================
# Application Configuration
# =============================================================================

# Display name shown in the navigation bar
MALLA_NAME=Malla

# Flask secret key (change this for production!)
MALLA_SECRET_KEY=your-secret-key-here

# Enable debug mode (DO NOT use in production)
MALLA_DEBUG=false

# =============================================================================
# Meshpipe (MQTT capture) configuration (Required)
# =============================================================================

# Meshpipe broker address (REQUIRED - set this to your broker's IP/hostname)
MESHPIPE_MQTT_BROKER_ADDRESS=127.0.0.1

# Meshpipe broker port (default: 1883)
MESHPIPE_MQTT_PORT=1883

# Meshpipe authentication (optional)
MESHPIPE_MQTT_USERNAME=
MESHPIPE_MQTT_PASSWORD=

# Meshpipe topic configuration (defaults should work for most setups)
MESHPIPE_MQTT_TOPIC_PREFIX=msh
MESHPIPE_MQTT_TOPIC_SUFFIX=/+/+/+/#

# Default channel key for decrypting secondary channels (base64, optional). Leave unset to disable.
# MESHPIPE_DEFAULT_CHANNEL_KEY=

# Persist raw MQTT payloads (set to "false" to disable raw storage)
# MESHPIPE_CAPTURE_STORE_RAW=true

# Observability (Prometheus / healthz)
# MESHPIPE_OBSERVABILITY_ADDRESS=:2112
# MESHPIPE_METRICS_PORT=2112

# Optional: mirror the broker details for the web UI dashboard (legacy naming)
# MALLA_MQTT_BROKER_ADDRESS=$MESHPIPE_MQTT_BROKER_ADDRESS
# MALLA_MQTT_PORT=$MESHPIPE_MQTT_PORT
# MALLA_MQTT_TOPIC_PREFIX=$MESHPIPE_MQTT_TOPIC_PREFIX
# MALLA_MQTT_TOPIC_SUFFIX=$MESHPIPE_MQTT_TOPIC_SUFFIX
# MALLA_DEFAULT_CHANNEL_KEY=$MESHPIPE_DEFAULT_CHANNEL_KEY

# =============================================================================
# Optional hardening & debugging toggles
# =============================================================================

# Open the SQLite database in read-only mode from the web container (recommended in prod)
# MALLA_DATABASE_READ_ONLY=true

# Honour proxy-provided headers (enable when running behind a trusted reverse proxy)
# MALLA_TRUST_PROXY_HEADERS=true

# Comma-separated host allowlist (e.g. "malla.meshworks.ru,localhost")
# MALLA_ALLOWED_HOSTS=

# Simple rate limit rule applied via Flask-Limiter (e.g. "200 per minute")
# MALLA_DEFAULT_RATE_LIMIT=

# Enable debug blueprint + browser console (dev only); provide a token if exposed
# MALLA_ENABLE_BROWSER_DEBUG=false
# MALLA_DEBUG_TOKEN=
# MALLA_DEBUG_LOG_BUFFER_SIZE=500

# Keep the stock Leaflet attribution link/emoji on the map
# MALLA_MAP_SHOW_LEAFLET_BRANDING=false

# Persist raw MQTT payloads to SQLite (set 0 to drop large blobs)
# MALLA_CAPTURE_STORE_RAW=1

# =============================================================================
# Meshpipe gRPC integration (toggle once Meshpipe exposes the richer API)
# =============================================================================

# Enable the gRPC data source (defaults to SQLite access today)
# MALLA_MESHPIPE_USE_GRPC=false

# Direct Meshpipe gRPC endpoint (host:port). Useful when running without Envoy.
# MALLA_MESHPIPE_GRPC_ENDPOINT=meshpipe:7443

# Route gRPC through the Envoy sidecar instead of the direct endpoint.
# MALLA_MESHPIPE_GRPC_USE_PROXY=true
# MALLA_MESHPIPE_GRPC_PROXY_ENDPOINT=meshpipe-proxy:8443

# Optional bearer token sent as `Authorization: Bearer <token>` metadata.
# MALLA_MESHPIPE_GRPC_TOKEN=

# Per-request timeout for Meshpipe gRPC calls (seconds).
# MALLA_MESHPIPE_GRPC_TIMEOUT_SECONDS=5.0
